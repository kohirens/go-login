{
  "$id": "https://github.com/kohirens/go-login/blob/main/schemas/profile.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "profile",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "A unique identifier."
    },
    "name": {
      "type": "string",
      "description": "A nick name for the profile."
    },
    "userInfo": {
      "description": "Information about the user.",
      "$ref": "https://github.com/kohirens/go-login/blob/main/schemas/userinfo.schema.json"
    },
    "username": {
      "description": "Username chosen to log into the site.",
      "type": "string"
    },
    "password": {
      "description": "Password chosen to log into the site.",
      "type": "string"
    },
    "clientApps": {
      "type": "object",
      "description": "Map of client apps used to login to the account.",
      "properties": {
      }
    },
    "required": [
      "id",
      "name",
      "userInfo"
    ]
  }
}